# LLM Provider (Using OpenAI SDK standard, supports OpenAI/Groq/etc)
OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=https://api.groq.com/openai/v1  # Optional: for Groq
# OPENAI_MODEL=gpt-4o                             # Optional: Default model

# Headless mode for Playwright (set to false to watch the agent work)
HEADLESS=false

# Note: Product credentials are NOT stored here. 
# We use a persistent browser context to manage Google SSO sessions.
